{
  "schemaVersion": 1,
  "id": "maeve",
  "version": "${version}",
  "name": "Maeve",
  "description": "Server-legal performance + quality-of-life client: HUD, mod menu, cosmetics.",
  "authors": ["Maeve"],
  "contact": {
    "homepage": "https://github.com/Bihzeh/maeve",
    "sources": "https://github.com/Bihzeh/maeve",
    "issues": "https://github.com/Bihzeh/maeve/issues"
  },
  "license": "LicenseRef-Maeve-Proprietary",
  "environment": "client",
  "entrypoints": {
    "client": [
      { "adapter": "kotlin", "value": "gg.maeve.mod.MaeveMod" }
    ]
  },
  "mixins": [
    { "config": "maeve.mixins.json", "environment": "client" }
  ],
  "depends": {
    "fabricloader": ">=${loader}",
    "minecraft": "~${minecraft}",
    "java": ">=25",
    "fabric-api": "*",
    "fabric-language-kotlin": "*"
  }
}
